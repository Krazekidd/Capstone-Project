# Ollama Configuration
# Copy this file to .env and set your preferred values

# Model to use for Ollama
OLLAMA_MODEL=qwen2.5:3b

# Context window size in tokens
# Standard context for recommend and chat endpoints
# Common values: 2048, 4096, 8192
# Default: 4096
OLLAMA_CONTEXT_SIZE=4096

# Larger context window for chatbot with memory
# Chatbot needs more context for conversation history
# Common values: 8192, 16384, 32768
# Default: 16384
OLLAMA_CHATBOT_CONTEXT_SIZE=16384

# Database Configuration
# PostgreSQL database URL for conversation storage
# Default: localhost PostgreSQL from Docker Compose
DATABASE_URL=postgresql://ollama_user:ollama_pass@localhost:5432/ollama_chat
